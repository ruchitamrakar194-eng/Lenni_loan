t>2. SCOPE OF AGREEMENT</w:t></w:r></w:p><w:p w14:paraId="67C8C98C" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>2.1</w:t></w:r></w:p><w:p w14:paraId="1CE8E577" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:t>The Service Provider is a registered credit provider that provides salary-linked and short-term credit facilities in compliance with the provisions of the National Credit Act and all applicable South African legislation.</w:t></w:r></w:p><w:p w14:paraId="2DB7C565" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>2.2</w:t></w:r></w:p><w:p w14:paraId="7E1C923F" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:t>The Employer agrees, subject to the terms and conditions of this Agreement and subject to the written consent and/or authority of the relevant employee, to assist in facilitating and administering authorised salary deductions in respect of loan instalments due by eligible employees to Lenni (Pty) Ltd.</w:t></w:r></w:p><w:p w14:paraId="292383EF" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>2.3</w:t></w:r></w:p><w:p w14:paraId="528923D7" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:t>The Parties acknowledge that all salary deductions shall be authorised by the employee in accordance with applicable legislation, including:</w:t></w:r></w:p><w:p w14:paraId="7230DBE6" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:lastRenderedPageBreak/><w:t xml:space="preserve">the Basic Conditions of Employment Act; </w:t></w:r></w:p><w:p w14:paraId="5770FCDE" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:t xml:space="preserve">the National Credit Act; and </w:t></w:r></w:p><w:p w14:paraId="24A1A34C" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:t xml:space="preserve">Information Regulator POPIA requirements. </w:t></w:r></w:p><w:p w14:paraId="68025B7F" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:pict w14:anchorId="6E8A7A18"><v:rect id="_x0000_i1027" style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" fillcolor="#a0a0a0" stroked="f"/></w:pict></w:r></w:p><w:p w14:paraId="3D7CFC84" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>3. RESPONSIBILITIES OF THE SERVICE PROVIDER</w:t></w:r></w:p><w:p w14:paraId="7EF02493" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:t>The Service Provider hereby undertakes and warrants that:</w:t></w:r></w:p><w:p w14:paraId="5DB80653" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>3.1</w:t></w:r></w:p><w:p w14:paraId="77D77FC8" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:t>It shall maintain all registrations, licences, and approvals required to operate as a credit provider in South Africa.</w:t></w:r></w:p><w:p w14:paraId="214E0F7F" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>3.2</w:t></w:r></w:p><w:p w14:paraId="4AB54E15" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:t>It shall conduct affordability assessments and credit vetting in accordance with the National Credit Act.</w:t></w:r></w:p><w:p w14:paraId="28815864" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>3.3</w:t></w:r></w:p><w:p w14:paraId="0528C93A" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:t>It shall ensure that all employee loan applications and salary deductions are properly authorised by the employee.</w:t></w:r></w:p><w:p w14:paraId="08BC61D5" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00505D3F"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>3.4</w:t></w:r></w:p><w:p w14:paraId="3E01DEDA" w14:textId="77777777" w:rsidR="00505D3F" w:rsidRPr="00505D3F" w:rsidRDefault="00505D3F" w:rsidP="00505D3F"><w:r w:rsidRPr="00505D3F"><w:t>It shall maintain appropriate system